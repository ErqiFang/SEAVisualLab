TOKENPLAN_API_KEY=
TOKENPLAN_BASE_URL=https://api.minimax.io
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_IMAGE_MODEL=image-01
ENABLE_REAL_GENERATION=true
ENABLE_FALLBACK_MOCK=true
